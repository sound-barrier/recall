{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [{"title": "Recall dashboards", "type": "dashboards", "tags": ["recall"], "asDropdown": true, "includeVars": true, "keepTime": true}],
  "templating": {"list": [
    {
      "name": "rank", "label": "Rank tier", "type": "query",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "definition": "label_values(recall_match_win, rank)",
      "query": {"qryType": 1, "query": "label_values(recall_match_win, rank)", "refId": "rank"},
      "includeAll": true, "allValue": ".*", "multi": true, "refresh": 2,
      "current": {"text": "All", "value": "$__all"}, "sort": 1
    }
  ]},
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Win rate by map — sorted worst → best",
      "description": "avg(recall_match_win) per map for the selected rank tier.",
      "gridPos": {"h": 11, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (map) (count_over_time(recall_match_win{map!=\"\",rank=~\"$rank\"}[365d]))", "format": "table", "instant": true, "refId": "Matches"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "avg by (map) (avg_over_time(recall_match_win{map!=\"\",rank=~\"$rank\"}[365d]))", "format": "table", "instant": true, "refId": "WinRate"}
      ],
      "transformations": [
        {"id": "merge", "options": {}},
        {"id": "organize", "options": {
          "excludeByName": {"Time": true, "Time 1": true, "Time 2": true, "__name__": true},
          "indexByName": {"map": 0, "Value #Matches": 1, "Value #WinRate": 2},
          "renameByName": {"map": "Map", "Value #Matches": "Matches", "Value #WinRate": "Win Rate"}
        }}
      ],
      "options": {"showHeader": true, "sortBy": [{"desc": false, "displayName": "Win Rate"}]},
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto", "displayMode": "auto", "filterable": true}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Map"}, "properties": [{"id": "custom.width", "value": 160}]},
          {"matcher": {"id": "byName", "options": "Win Rate"}, "properties": [
            {"id": "unit", "value": "percentunit"}, {"id": "decimals", "value": 0},
            {"id": "max", "value": 1}, {"id": "min", "value": 0},
            {"id": "custom.displayMode", "value": "gradient-gauge"},
            {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.4}, {"color": "green", "value": 0.55}]}}
          ]}
        ]
      }
    },
    {
      "id": 2,
      "type": "table",
      "title": "Win rate by game type — sorted worst → best",
      "description": "Control / Escort / Hybrid / Push / Flashpoint / Clash. Pick favored modes when you can.",
      "gridPos": {"h": 11, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (game_mode) (count_over_time(recall_match_win{game_mode!=\"\",rank=~\"$rank\"}[365d]))", "format": "table", "instant": true, "refId": "Matches"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "avg by (game_mode) (avg_over_time(recall_match_win{game_mode!=\"\",rank=~\"$rank\"}[365d]))", "format": "table", "instant": true, "refId": "WinRate"}
      ],
      "transformations": [
        {"id": "merge", "options": {}},
        {"id": "organize", "options": {
          "excludeByName": {"Time": true, "Time 1": true, "Time 2": true, "__name__": true},
          "indexByName": {"game_mode": 0, "Value #Matches": 1, "Value #WinRate": 2},
          "renameByName": {"game_mode": "Game type", "Value #Matches": "Matches", "Value #WinRate": "Win Rate"}
        }}
      ],
      "options": {"showHeader": true, "sortBy": [{"desc": false, "displayName": "Win Rate"}]},
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto", "displayMode": "auto", "filterable": false}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Game type"}, "properties": [{"id": "custom.width", "value": 130}]},
          {"matcher": {"id": "byName", "options": "Win Rate"}, "properties": [
            {"id": "unit", "value": "percentunit"}, {"id": "decimals", "value": 0},
            {"id": "max", "value": 1}, {"id": "min", "value": 0},
            {"id": "custom.displayMode", "value": "gradient-gauge"},
            {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.4}, {"color": "green", "value": 0.55}]}}
          ]}
        ]
      }
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Win rate by queue type (5v5 role vs 6v6 open)",
      "description": "Different metas, different comfort. avg(recall_match_win) per queue for the selected rank.",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 11},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "avg by (queue_type) (avg_over_time(recall_match_win{queue_type!=\"\",rank=~\"$rank\"}[365d]))", "legendFormat": "{{queue_type}}", "instant": true, "refId": "A"}],
      "options": {"displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true, "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.4}, {"color": "green", "value": 0.55}]}}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "KDA per match by queue type",
      "description": "(eliminations + assists) / max(deaths, 1), split by 5v5 vs 6v6.",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 11},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "(sum by (queue_type) (recall_match_eliminations{queue_type!=\"\",rank=~\"$rank\"}) + sum by (queue_type) (recall_match_assists{queue_type!=\"\",rank=~\"$rank\"})) / clamp_min(sum by (queue_type) (recall_match_deaths{queue_type!=\"\",rank=~\"$rank\"}), 1)", "legendFormat": "{{queue_type}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 8, "pointSize": 6, "showPoints": "always", "spanNulls": true}, "decimals": 2}},
      "options": {"legend": {"calcs": ["mean"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "none"}}
    },
    {
      "id": 5,
      "type": "table",
      "title": "Map × Hero — pocket picks per map",
      "description": "Which hero wins you each map (for the selected rank). Sort Matches desc for your staples, Win Rate desc for hidden gems.",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (map, hero) (count_over_time(recall_match_win{map!=\"\",hero!=\"\",rank=~\"$rank\"}[365d]))", "format": "table", "instant": true, "refId": "Matches"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "avg by (map, hero) (avg_over_time(recall_match_win{map!=\"\",hero!=\"\",rank=~\"$rank\"}[365d]))", "format": "table", "instant": true, "refId": "WinRate"}
      ],
      "transformations": [
        {"id": "merge", "options": {}},
        {"id": "organize", "options": {
          "excludeByName": {"Time": true, "Time 1": true, "Time 2": true, "__name__": true},
          "indexByName": {"map": 0, "hero": 1, "Value #Matches": 2, "Value #WinRate": 3},
          "renameByName": {"map": "Map", "hero": "Hero", "Value #Matches": "Matches", "Value #WinRate": "Win Rate"}
        }}
      ],
      "options": {"showHeader": true, "sortBy": [{"desc": true, "displayName": "Matches"}]},
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto", "displayMode": "auto", "filterable": true}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Win Rate"}, "properties": [
            {"id": "unit", "value": "percentunit"}, {"id": "decimals", "value": 0},
            {"id": "max", "value": 1}, {"id": "min", "value": 0},
            {"id": "custom.displayMode", "value": "gradient-gauge"},
            {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.4}, {"color": "green", "value": 0.55}]}}
          ]}
        ]
      }
    }
  ],
