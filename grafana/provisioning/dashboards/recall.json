      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (hero) (count_over_time(recall_match_result{hero!=\"\"}[365d]))", "format": "table", "instant": true, "refId": "Matches"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "(sum by (hero) (count_over_time(recall_match_result{hero!=\"\",result=\"victory\"}[365d]))) or (sum by (hero) (count_over_time(recall_match_result{hero!=\"\"}[365d])) * 0)", "format": "table", "instant": true, "refId": "Wins"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "(sum by (hero) (count_over_time(recall_match_result{hero!=\"\",result=\"defeat\"}[365d]))) or (sum by (hero) (count_over_time(recall_match_result{hero!=\"\"}[365d])) * 0)", "format": "table", "instant": true, "refId": "Losses"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "((sum by (hero) (count_over_time(recall_match_result{hero!=\"\",result=\"victory\"}[365d]))) or (sum by (hero) (count_over_time(recall_match_result{hero!=\"\"}[365d])) * 0)) / sum by (hero) (count_over_time(recall_match_result{hero!=\"\"}[365d]))", "format": "table", "instant": true, "refId": "WinRate"}
      ],
      "transformations": [
        {"id": "merge", "options": {}},
        {"id": "organize", "options": {
          "excludeByName": {"Time": true, "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "__name__": true},
          "indexByName": {"hero": 0, "Value #Matches": 1, "Value #Wins": 2, "Value #Losses": 3, "Value #WinRate": 4},
          "renameByName": {"hero": "Hero", "Value #Matches": "Matches", "Value #Wins": "Wins", "Value #Losses": "Losses", "Value #WinRate": "Win Rate"}
        }}
      ],
      "options": {"showHeader": true, "sortBy": [{"desc": false, "displayName": "Win Rate"}]},
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto", "displayMode": "auto", "filterable": false}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Hero"}, "properties": [{"id": "custom.width", "value": 120}]},
          {"matcher": {"id": "byName", "options": "Win Rate"}, "properties": [
            {"id": "unit", "value": "percentunit"},
            {"id": "decimals", "value": 0},
            {"id": "max", "value": 1},
            {"id": "min", "value": 0},
            {"id": "custom.displayMode", "value": "gradient-gauge"},
            {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.4}, {"color": "green", "value": 0.55}]}}
          ]}
