# direnv — run `direnv allow` after editing this file.
# Uncomment and adjust any vars you want set automatically on `cd`.

# Redirect `wails dev` (and `go run`) to keep settings + the SQLite DB
# under the repo's data/ dir, so the database is easy to inspect with
# GoLand / sqlite3 and survives `git clean`-safe destruction. Released
# app launches don't have .envrc loaded, so this stays unset and the
# platform user-config dir applies — see appDataDir() in
# pkg/app/settings.go for the fall-through behavior.
export RECALL_DATA_DIR="$PWD/data"

# Directory for Tesseract work files (default: system temp).
# Set to a fixed path to inspect OCR intermediates after a parse run.
# export RECALL_DEBUG_DIR=/tmp/recall-debug

# Prometheus metrics bind address (default: :9091).
# export RECALL_METRICS_ADDR=:9091

# HTTP server bind address (default: 127.0.0.1:7000).
# Set to 0.0.0.0:7000 to accept connections from other hosts.
# export RECALL_SERVER_ADDR=127.0.0.1:7000

# Use Podman instead of Docker for make build-* targets.
# export DOCKER=podman
