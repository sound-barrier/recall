# Shared ShellCheck configuration for the Recall repo's scripts/.
#
# source-path=SCRIPTDIR tells ShellCheck to resolve every
#   # shellcheck source=<rel-path>
# directive (e.g. the `_lib.sh` source in scripts/stack/stack-up.sh and
# scripts/stack/prometheus-clear.sh) relative to the *script being analyzed*
# rather than ShellCheck's own working directory. Without this, running
# `shellcheck scripts/*.sh` from the project root reports SC1091 ("Not
# following: _lib.sh: does not exist") even though the directive is
# correct — the path is relative to the source file, not CWD.
source-path=SCRIPTDIR

# external-sources lets ShellCheck actually FOLLOW those `source=`
# directives to files that aren't themselves in the input set.
# `make lint-shell` passes every script at once, so the sourced libs are
# always present and SC1091 stays quiet — but lefthook's pre-commit hook
# runs `shellcheck {staged_files}`, so committing a lib-sourcing script
# (e.g. scripts/stack/stack-up.sh) WITHOUT staging scripts/lib/ makes the
# lib "external" and trips SC1091. Allowing external sources resolves the
# directive the same way CI does. Safe because every source= path is a
# checked-in, version-controlled sibling.
external-sources=true
