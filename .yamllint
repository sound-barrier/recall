extends: default

rules:
  # Line length is intentionally NOT enforced for YAML. GitHub Actions
  # run: blocks, long label strings, and URLs routinely run long, and
  # rewrapping them hurts readability more than it helps. yamllint still
  # validates that every file is well-formed, correctly-indented YAML.
  line-length: disable

  # --- prefix is optional for config files in this repo.
  document-start: disable

  # GitHub Actions uses true/false and bare `on:` as the trigger key (YAML 1.1
  # interprets `on`/`off` as truthy booleans, so we allow them explicitly).
  # `off` is a legitimate string value too — Spectral rule toggles
  # (`operation-operationId: off`) and action inputs (`comment_mode: off`).
  truthy:
    allowed-values: ['true', 'false', 'on', 'off']
    level: warning

ignore: |
  frontend/node_modules/
  dist/
  build/bin/
  # OpenAPI spec uses aligned flow-style mappings (a common OpenAPI idiom
  # that yamllint's default flow-mapping rules flag). The spec is linted
  # by Spectral via `task lint-openapi`, which understands OpenAPI shape
  # semantics rather than generic YAML style.
  api/openapi.yaml
