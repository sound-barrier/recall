{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint:js": "eslint . --max-warnings 0",
    "lint:css": "stylelint 'src/**/*.{css,vue}'",
    "lint:html": "htmlhint --config .htmlhintrc index.html ../docs/api/index.html",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "gen:types": "openapi-typescript ../api/openapi.yaml -o src/api.gen.d.ts",
    "dead:ts": "knip",
    "postinstall": "node ./scripts/seed-go-sentinel.cjs"
  },
  "dependencies": {
    "echarts": "^5.6.0",
    "vue": "^3.5.35",
    "vue-echarts": "^7.0.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.2",
    "htmlhint": "^1.9.2",
    "knip": "^6.16.1",
    "monocart-coverage-reports": "^2.12.12",
    "openapi-typescript": "^7.13.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.4"
  }
}
