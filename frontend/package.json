{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint:js": "eslint src",
    "lint:css": "stylelint 'src/**/*.{css,vue}'",
    "lint:html": "htmlhint index.html",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "gen:types": "openapi-typescript ../api/openapi.yaml -o src/api.gen.d.ts",
    "dead:ts": "knip"
  },
  "dependencies": {
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "htmlhint": "^1.9.2",
    "knip": "^6.14.1",
    "openapi-typescript": "^7.13.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.11.1",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.3.1"
  }
}
