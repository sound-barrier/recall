# Supply-chain cooldown: reject npm package versions younger than the
# given number of days. Catches the typical hijacked-publish → npm
# unpublish window (Shai-Hulud + the 2025 worm wave were all pulled
# inside 72 h) without delaying anything else. Requires npm ≥ 11.0 —
# CI runs Node 26 (npm 11.x), Dockerfile.build uses node:26-slim,
# initialize.sh + .devcontainer track the same major.
#
# Emergency CVE override (per invocation):
#   npm install <pkg> --min-release-age=0
#
# Documented in CONTRIBUTING.md → "npm supply-chain cooldown".
min-release-age=7
